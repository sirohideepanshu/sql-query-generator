# Secret key used for signing JWT tokens. Change this to a secure random string in production.
SECRET_KEY=your-super-secret-jwt-key

# Database URL. Defaults to SQLite for local development.
# For SQLite: sqlite:///data/users.db
# For PostgreSQL: postgresql://username:password@host:port/database_name
# For MySQL: mysql+pymysql://username:password@host:port/database_name
DATABASE_URL=sqlite:///data/users.db

# API Key for Google Gemini (needed for NL2SQL query generation)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Custom encryption key for encrypting database passwords stored in SQL Assist database.
# Must be a 32-byte url-safe base64-encoded key if specified.
# If not set, a key is automatically derived from the SECRET_KEY.
# ENCRYPTION_KEY=
